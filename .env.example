# Copy to .env — never commit real values
DEPLOY_HOST=your-server.example.com
DEPLOY_USER=ubuntu
WEB_ROOT=/var/www/veritytech
PM2_PORT=8500
DOMAIN=veritytech.example.com

# Stock image APIs (free keys) — used by scripts/fetch-images.py at build time.
# Get keys: https://unsplash.com/developers  |  https://www.pexels.com/api/
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=

# Contact form delivery (optional). Set one:
# Formspree endpoint, e.g. https://formspree.io/f/xxxxxxx
CONTACT_FORM_ENDPOINT=
